<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>
ดูซีรีส์ รักได้หรือ Young EP1-EP19 พากย์ไทย ย้อนหลังครบทุกตอน ดูฟรี HD
</title>

<meta name="description"
content="ดูซีรีส์ รักได้หรือ Young EP1-EP19 พากย์ไทย HD ครบทุกตอน ฟรี รองรับมือถือ">

<style>

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

body{
  background:#080808;
  color:#fff;
  font-family:Arial,sans-serif;
  overflow-x:hidden;
}

.container{
  width:100%;
  max-width:1300px;
  margin:auto;
  padding:15px;
}

/* =========================
ADS
========================= */

.ad-wrap{
  width:100%;
  display:flex;
  justify-content:center;
  align-items:center;
  margin:18px 0;
  overflow:hidden;
}

.ad-box{
  display:flex;
  justify-content:center;
  align-items:center;
  overflow:hidden;
  max-width:100%;
}

.page-layout{
  display:grid;
  grid-template-columns:minmax(0,1fr) 180px;
  gap:20px;
  align-items:start;
}

.sidebar-ads{
  position:sticky;
  top:15px;
  display:flex;
  flex-direction:column;
  gap:18px;
}

.mobile-sticky-ad{
  position:fixed;
  bottom:0;
  left:0;
  width:100%;
  background:#0f0f0f;
  padding:6px 0;
  display:flex;
  justify-content:center;
  z-index:99999;
  box-shadow:0 -2px 10px rgba(0,0,0,.4);
}

.mobile-sticky-inner{
  width:320px;
  height:50px;
  overflow:hidden;
}

@media(max-width:1024px){

  .page-layout{
    grid-template-columns:1fr;
  }

  .sidebar-ads{
    display:none;
  }

}

@media(min-width:769px){

  .mobile-sticky-ad{
    display:none;
  }

}

@media(max-width:768px){

  body{
    padding-bottom:70px;
  }

}

/* =========================
HERO
========================= */

.hero{
  position:relative;
  border-radius:20px;
  overflow:hidden;
  margin-bottom:25px;
}

.hero img{
  width:100%;
  height:450px;
  object-fit:cover;
  filter:brightness(.45);
}

.hero-overlay{
  position:absolute;
  inset:0;
  display:flex;
  flex-direction:column;
  justify-content:flex-end;
  padding:35px;
  background:linear-gradient(to top,
  rgba(0,0,0,.95),
  transparent);
}

.title{
  font-size:42px;
  font-weight:bold;
  margin-bottom:10px;
}

.desc{
  max-width:720px;
  line-height:1.7;
  color:#ddd;
}

.tags{
  margin-top:18px;
  display:flex;
  flex-wrap:wrap;
  gap:10px;
}

.tags span{
  background:#e50914;
  padding:7px 14px;
  border-radius:40px;
  font-size:12px;
  font-weight:bold;
}

/* =========================
EPISODES
========================= */

.section-title{
  margin-top:20px;
  margin-bottom:18px;
  font-size:28px;
  font-weight:bold;
}

.episodes{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(170px,1fr));
  gap:16px;
}

.ep-card{
  background:#111;
  border:1px solid #222;
  border-radius:14px;
  overflow:hidden;
  transition:.3s;
  cursor:pointer;
}

.ep-card:hover{
  transform:translateY(-4px);
  border-color:#e50914;
}

.ep-thumb{
  width:100%;
  height:100px;
  object-fit:cover;
}

.ep-info{
  padding:14px;
}

.ep-title{
  font-size:16px;
  font-weight:bold;
  margin-bottom:6px;
}

.ep-desc{
  font-size:12px;
  color:#aaa;
}

/* =========================
MOBILE
========================= */

@media(max-width:768px){

  .hero img{
    height:320px;
  }

  .hero-overlay{
    padding:20px;
  }

  .title{
    font-size:28px;
  }

}

</style>
</head>

<body>

<script>

const SERIES_THUMBNAIL =
