<script>

/* HERO IMAGE */

document.getElementById("heroImage").src =
SERIES_THUMBNAIL;

/* EPISODES */

const episodesContainer =
document.getElementById("episodesContainer");

for(let i=1;i<=19;i++){

episodesContainer.innerHTML += `

<div class="ep-card"
onclick="goEpisode(${i})">

<img
src="${SERIES_THUMBNAIL}"
class="ep-thumb"
>

<div class="ep-info">

<div class="ep-title">
EP ${i}
</div>

<div class="ep-desc">
ดูตอนที่ ${i} แบบ HD
</div>

</div>

</div>

`;

}

/* EPISODE LINK */

function goEpisode(ep){

  window.location.href =
  "https://goseriesthai.pages.dev/ruk-ruer-young/ep" +
  ep +
  ".html";

}

</script>

